{
  "resourceName": "AADGroupsSettings",
  "description": "This resource configures the Azure Active Directory groups settings.",
  "roles": {
    "read": [],
    "update": [
      "Groups Administrator"
    ]
  },
  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "Group.Read.All"
          },
          {
            "name": "GroupSettings.Read.All"
          }
        ],
        "update": [
          {
            "name": "Group.Read.All"
          },
          {
            "name": "GroupSettings.ReadWrite.All"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "Group.Read.All"
          },
          {
            "name": "GroupSettings.Read.All"
          }
        ],
        "update": [
          {
            "name": "Group.Read.All"
          },
          {
            "name": "GroupSettings.ReadWrite.All"
          }
        ]
      }
    }
  },
  "requiredModules": [
    "Microsoft.Graph.Authentication",
    "Microsoft.Graph.Beta.Identity.DirectoryManagement",
    "Microsoft.Graph.Groups"
  ],
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Configuration",
  "commands": [
    {
      "module": "Microsoft.Graph.Beta.Identity.DirectoryManagement",
      "cmdlets": [
        "Get-MgBetaDirectorySetting",
        "New-MgBetaDirectorySetting",
        "Update-MgBetaDirectorySetting"
      ]
    },
    {
      "module": "Microsoft.Graph.Groups",
      "cmdlets": [
        "Get-MgGroup"
      ]
    }
  ]
}
