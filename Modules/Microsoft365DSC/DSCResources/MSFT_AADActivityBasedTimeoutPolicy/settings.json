{
  "resourceName": "AADActivityBasedTimeoutPolicy",
  "description": "This resource configures an Azure AD Activity Based Timeout Policy.",
  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "Policy.Read.All"
          }
        ],
        "update": [
          {
            "name": "Policy.ReadWrite.ApplicationConfiguration"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "Policy.Read.All"
          }
        ],
        "update": [
          {
            "name": "Policy.ReadWrite.ApplicationConfiguration"
          }
        ]
      }
    }
  },
  "requiredModules": [
    "Microsoft.Graph.Authentication",
    "Microsoft.Graph.Beta.Identity.SignIns"
  ],
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Configuration"
}
