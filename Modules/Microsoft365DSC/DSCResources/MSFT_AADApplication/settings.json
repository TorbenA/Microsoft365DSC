{
  "resourceName": "AADApplication",
  "description": "This resource configures an Azure Active Directory Application.",
  "roles": {
    "read": [
      "Security Reader"
    ],
    "update": []
  },
  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "Application.Read.All"
          },
          {
            "name": "Policy.Read.All"
          }
        ],
        "update": [
          {
            "name": "Application.ReadWrite.All"
          },
          {
            "name": "User.Read.All"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "Application.Read.All"
          },
          {
            "name": "Policy.Read.All"
          }
        ],
        "update": [
          {
            "name": "Application.ReadWrite.All"
          },
          {
            "name": "User.Read.All"
          }
        ]
      }
    }
  },
  "requiredModules": [
    "Microsoft.Graph.Applications",
    "Microsoft.Graph.Authentication",
    "Microsoft.Graph.Beta.Applications",
    "Microsoft.Graph.Beta.Identity.DirectoryManagement",
    "Microsoft.Graph.Users",
    "MSCloudLoginAssistant"
  ],
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Data",
  "commands": [
    {
      "module": "Microsoft.Graph.Applications",
      "cmdlets": [
        "Get-MgApplication",
        "Get-MgServicePrincipal",
        "New-MgApplication",
        "New-MgApplicationOwnerByRef",
        "Remove-MgApplication",
        "Remove-MgApplicationOwnerDirectoryObjectByRef",
        "Update-MgApplication"
      ]
    },
    {
      "module": "Microsoft.Graph.Authentication",
      "cmdlets": [
        "Invoke-MgGraphRequest"
      ]
    },
    {
      "module": "Microsoft.Graph.Beta.Applications",
      "cmdlets": [
        "Get-MgBetaApplication",
        "Invoke-MgBetaInstantiateApplicationTemplate",
        "Update-MgBetaApplication"
      ]
    },
    {
      "module": "Microsoft.Graph.Beta.Identity.DirectoryManagement",
      "cmdlets": [
        "Get-MgBetaDirectoryDeletedItemAsApplication",
        "Restore-MgBetaDirectoryDeletedItem"
      ]
    },
    {
      "module": "Microsoft.Graph.Beta.Identity.SignIns",
      "cmdlets": [
        "Get-MgBetaPolicyTokenLifetimePolicy",
        "New-MgApplicationTokenLifetimePolicyByRef",
        "Remove-MgApplicationTokenLifetimePolicyByRef"
      ]
    },
    {
      "module": "Microsoft.Graph.Users",
      "cmdlets": [
        "Get-MgUser"
      ]
    }
  ]
}
