          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "Group.Read.All"
          },
          {
            "name": "DeviceManagementScripts.Read.All"
          }
        ],
        "update": [
          {
            "name": "Group.Read.All"
          },
          {
            "name": "DeviceManagementScripts.ReadWrite.All"
          }
        ]
      }
