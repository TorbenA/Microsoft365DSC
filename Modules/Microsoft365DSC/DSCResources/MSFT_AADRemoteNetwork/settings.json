{
  "resourceName": "AADRemoteNetwork",
  "description": "Use this resource to manage the Entra's Network Access Remote Networks, and related Device links.",
  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "NetworkAccess.Read.All"
          }
        ],
        "update": [
          {
            "name": "NetworkAccess.ReadWrite.All"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "NetworkAccess.Read.All"
          }
        ],
        "update": [
          {
            "name": "NetworkAccess.ReadWrite.All"
          }
        ]
      }
    }
  },
  "requiredModules": [
    "Microsoft.Graph.Authentication",
    "Microsoft.Graph.Beta.NetworkAccess",
    "MSCloudLoginAssistant"
  ],
  "supportedEnvironments": [
    "Global"
  ],
  "mode": "Configuration",
  "commands": [
    {
      "module": "Microsoft.Graph.Authentication",
      "cmdlets": [
        "Invoke-MgGraphRequest"
      ]
    },
    {
      "module": "Microsoft.Graph.Beta.NetworkAccess",
      "cmdlets": [
        "Get-MgBetaNetworkAccessConnectivityRemoteNetwork",
        "Get-MgBetaNetworkAccessForwardingProfile",
        "New-MgBetaNetworkAccessConnectivityRemoteNetwork",
        "New-MgBetaNetworkAccessConnectivityRemoteNetworkDeviceLink",
        "Remove-MgBetaNetworkAccessConnectivityRemoteNetwork",
        "Remove-MgBetaNetworkAccessConnectivityRemoteNetworkDeviceLink"
      ]
    }
  ]
}