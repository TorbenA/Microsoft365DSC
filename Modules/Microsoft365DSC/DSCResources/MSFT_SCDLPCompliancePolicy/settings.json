{
  "resourceName": "SCDLPCompliancePolicy",
  "description": "This resource configures a DLP Compliance Policy in Purview.",
  "roles": {
    "read": [
      "Security Reader"
    ],
    "update": [
      "Compliance Administrator"
    ]
  },
  "permissions": {
    "Office 365 Exchange Online": {
      "application": {
        "read": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ],
        "update": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ]
      }
    },
    "purview": {
      "requiredroles": {
        "read": [
          "Security Reader"
        ],
        "update": [
          "Organization Configuration"
        ]
      },
      "requiredrolegroups": {
        "read": [
          "Security Reader"
        ],
        "update": [
          "Compliance Data Administrator"
        ]
      }
    }
  },
  "requiredModules": [],
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Configuration"
}
