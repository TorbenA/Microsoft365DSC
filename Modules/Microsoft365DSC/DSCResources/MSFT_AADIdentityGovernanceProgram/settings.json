  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "ProgramControl.Read.All"
          }
        ],
        "update": [
          {
            "name": "ProgramControl.ReadWrite.All"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "ProgramControl.Read.All"
          }
        ],
        "update": [
          {
            "name": "ProgramControl.ReadWrite.All"
          }
        ]
      }
    }
  },
  "requiredModules": [
    "Microsoft.Graph.Beta.Identity.Governance"
  ],
  "supportedEnvironments": [
    "Global"
  ],
  "mode": "Configuration",
  "commands": [
    {
      "module": "Microsoft.Graph.Beta.Identity.Governance",
      "cmdlets": [
        "Get-MgBetaProgram",
        "New-MgBetaProgram",
        "Remove-MgBetaProgram",
        "Update-MgBetaProgram"
      ]
    }
  ]
