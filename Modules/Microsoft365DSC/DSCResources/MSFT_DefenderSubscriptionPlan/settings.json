        "Security Reader",
        "Security Admin"
      ]
    }
  },
  "requiredModules": [
    "Az.Accounts",
    "Az.ResourceGraph",
    "Az.Security"
  ],
  "mode": "Data",
  "commands": [
    {
      "module": "Az.Accounts",
      "cmdlets": [
        "Connect-AzAccount",
        "Get-AzContext",
        "Get-AzSubscription",
        "Register-AzModule",
        "Set-AzContext"
      ]
    },
    {
      "module": "Az.ResourceGraph",
      "cmdlets": [
        "Search-AzGraph"
      ]
    },
    {
      "module": "Az.Security",
      "cmdlets": [
        "Get-AzSecurityPricing",
        "Set-AzSecurityPricing"
      ]
    }
  ]
}
