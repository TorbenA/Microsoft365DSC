{
  "resourceName": "EXOMailboxFolderPermission",
  "description": "Use this resource to add/set/remove mailbox folder permissions for users in your tenant.",
  "roles": {
    "read": [
      "Global Reader"
    ],
    "update": [
      "Exchange Administrator"
    ]
  },
  "permissions": {
    "Office 365 Exchange Online": {
      "application": {
        "read": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ],
        "update": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ]
      }
    },
    "exchange": {
      "requiredroles": [
        "Organization Management",
        "Recipient Management"
      ],
      "requiredrolegroups": [
        "Organization Management",
        "Help Desk"
      ]
    }
  },
  "requiredModules": []
}
