{
  "resourceName": "EXOMigrationEndpoint",
  "description": "Use this resource to create and monitor migration endpoint in exchange",
  "roles": {
    "read": [
      "Global Reader"
    ],
    "update": [
      "Exchange Administrator"
    ]
  },
  "permissions": {
    "Office 365 Exchange Online": {
      "application": {
        "read": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ],
        "update": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ]
      }
    },
    "exchange": {
      "requiredroles": {
        "read": [
          "View-Only Configuration"
        ],
        "update": [
          "Migration"
        ]
      },
      "requiredrolegroups": {
        "read": [
          "View-Only Organization Management"
        ],
        "update": [
          "Recipient Management"
        ]
      }
    }
  },
  "requiredModules": [],
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Configuration"
}
