{
  "resourceName": "AADDomainFederation",
  "description": "Manages Azure Active Directory Domain Federation configurations including SAML/WS-Fed settings, signing certificates, and authentication protocols for federated domains.",
  "roles": {
    "read": [
      "Domain Administrator",
      "Global Reader"
    ],
    "update": [
      "Domain Administrator",
      "Global Administrator"
    ]
  },
  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "Domain.Read.All"
          }
        ],
        "update": [
          {
            "name": "Domain.ReadWrite.All"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "Domain.Read.All"
          }
        ],
        "update": [
          {
            "name": "Domain.ReadWrite.All"
          }
        ]
      }
    }
  },
  "requiredModules": [
    "Microsoft.Graph.Authentication",
    "Microsoft.Graph.Beta.Identity.DirectoryManagement"
  ],
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Configuration",
  "commands": [
    {
      "module": "Microsoft.Graph.Beta.Identity.DirectoryManagement",
      "cmdlets": [
        "Get-MgBetaDomain",
        "Get-MgBetaDomainFederationConfiguration",
        "New-MgBetaDomainFederationConfiguration",
        "Remove-MgBetaDomainFederationConfiguration",
        "Update-MgBetaDomainFederationConfiguration"
      ]
    }
  ]
}
