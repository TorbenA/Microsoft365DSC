{
  "resourceName": "EXOManagementScope",
  "description": "Use this resource to create Management Scope.",
  "roles": {
    "read": [
      "Global Reader"
    ],
    "update": [
      "Exchange Administrator"
    ]
  },
  "permissions": {
    "Office 365 Exchange Online": {
      "application": {
        "read": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ],
        "update": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ]
      }
    },
    "exchange": {
      "requiredroles": [
        "Hygiene Management",
        "Compliance Management",
        "Organization Management",
        "View-Only Organization Management"
      ],
      "requiredrolegroups": [
        "Organization Management"
      ]
    }
  },
  "requiredModules": []
}
