{
  "resourceName": "SCSupervisoryReviewPolicy",
  "description": "This resource configures a Supervisory Review Policy in Purview.",
  "roles": {
    "read": [
      "Compliance Administrator"
    ],
    "update": [
      "Compliance Administrator"
    ]
  },
  "permissions": {
    "Office 365 Exchange Online": {
      "application": {
        "read": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ],
        "update": [
          {
            "name": "Exchange.ManageAsApp"
          }
        ]
      }
    },
    "purview":{
      "requiredroles": [
        "Security Reader",
        "Supervisory Review Administrator"
      ],
      "requiredrolegroups":[
        "Global Reader",
        "Supervisory Review"
      ]
    }
  },
  "requiredModules": [],
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Configuration"
}
