    "USGov"
  ],
  "mode": "Configuration",
  "commands": [
    {
      "module": "Microsoft.Graph.Beta.Identity.Governance",
      "cmdlets": [
        "Get-MgBetaEntitlementManagementAccessPackage",
        "Get-MgBetaEntitlementManagementAccessPackageCatalog",
