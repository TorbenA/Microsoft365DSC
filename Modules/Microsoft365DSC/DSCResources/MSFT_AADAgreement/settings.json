{
  "resourceName": "AADAgreement",
  "description": "This resource configures Azure AD Terms of Use Agreements in Entra ID.",
  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "Agreement.Read.All"
          }
        ],
        "update": [
          {
            "name": "Agreement.ReadWrite.All"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "Agreement.Read.All"
          }
        ],
        "update": [
          {
            "name": "Agreement.ReadWrite.All"
          }
        ]
      }
    }
  },
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Configuration",
  "commands": [
    {
      "module": "Microsoft.Graph.Authentication",
      "cmdlets": [
        "Invoke-MgGraphRequest"
      ]
    },
    {
      "module": "Microsoft.Graph.Beta.Identity.Governance",
      "cmdlets": [
        "Get-MgBetaAgreement",
        "Remove-MgBetaAgreement"
      ]
    }
  ]
}
