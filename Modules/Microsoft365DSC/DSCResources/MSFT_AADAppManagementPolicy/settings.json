{
  "resourceName": "AADAppManagementPolicy",
  "description": "Manages an app management policy that can be assigned to an application or service principal object.",
  "roles": {
    "read": [
      "Application Administrator"
    ],
    "update": [
      "Application Administrator"
    ]
  },
  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "Policy.Read.All"
          }
        ],
        "update": [
          {
            "name": "Policy.ReadWrite.ApplicationConfiguration"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "Policy.Read.All"
          }
        ],
        "update": [
          {
            "name": "Policy.ReadWrite.ApplicationConfiguration"
          }
        ]
      }
    }
  },
  "requiredModules": [
    "Microsoft.Graph.Authentication",
    "Microsoft.Graph.Beta.Identity.SignIns"
  ],
  "supportedEnvironments": [
    "Global",
    "USGov"
  ],
  "mode": "Configuration"
}
