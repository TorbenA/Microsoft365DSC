        "read": [
          {
            "name": "Policy.Read.B2BManagementPolicy"
          }
        ],
        "update": [
          {
            "name": "Policy.ReadWrite.B2BManagementPolicy"
          }
        ]
      },
      "delegated": {
        "read": [
          {
            "name": "Policy.Read.B2BManagementPolicy"
          }
        ],
        "update": [
          {
            "name": "Policy.ReadWrite.B2BManagementPolicy"
          }
        ]
      }
    }
  },
