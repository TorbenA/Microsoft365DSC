{
  "resourceName": "AADNetworkAccessForwardingPolicy",
  "description": "Use this resource to monitor the forwarding policy rules associated with the forwarding policies.",
  "permissions": {
    "graph": {
      "delegated": {
        "read": [
          {
            "name": "NetworkAccessPolicy.Read.All"
          }
        ],
        "update": [
          {
            "name": "NetworkAccessPolicy.ReadWrite.All"
          }
        ]
      },
      "application": {
        "read": [
          {
            "name": "NetworkAccessPolicy.Read.All"
          }
        ],
        "update": [
          {
            "name": "NetworkAccessPolicy.ReadWrite.All"
          }
        ]
      }
    }
  },
  "requiredModules": [
    "Microsoft.Graph.Authentication",
    "Microsoft.Graph.Beta.NetworkAccess",
    "MSCloudLoginAssistant"
  ],
  "supportedEnvironments": [
    "Global"
  ],
  "mode": "Configuration",
  "commands": [
    {
      "module": "Microsoft.Graph.Authentication",
      "cmdlets": [
        "Invoke-MgGraphRequest"
      ]
    },
    {
      "module": "Microsoft.Graph.Beta.NetworkAccess",
      "cmdlets": [
        "Get-MgBetaNetworkAccessForwardingPolicy",
        "New-MgBetaNetworkAccessForwardingPolicyRule",
        "Remove-MgBetaNetworkAccessForwardingPolicyRule"
      ]
    },
    {
      "module": "MSCloudLoginAssistant",
      "cmdlets": [
        "Get-MSCloudLoginConnectionProfile"
      ]
    }
  ]
}
